@model List<_991733370_ASSET_CLIENT.Models.EquipmentResponse>
@{
    ViewData["Title"] = "Equipment";
    var role = Context.Session.GetString("UserRole") ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Equipment Inventory</h2>
    @if (role == "ITAdmin")
    {
        <a asp-action="Create" class="btn btn-primary">+ Add Equipment</a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No equipment records found.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Asset Tag</th>
                        <th>Device Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.EquipmentId</td>
                            <td><code>@item.AssetTag</code></td>
                            <td>@item.DeviceName</td>
                            <td class="text-muted small">@(item.Description ?? "—")</td>
                            <td>
                                @if (item.IsAvailable)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Checked Out</span>
                                }
                            </td>
                            <td>
                                @if (item.IsAvailable)
                                {
                                    <form asp-action="Checkout" asp-route-id="@item.EquipmentId"
                                          method="post" class="d-inline">
                                        <button type="submit" class="btn btn-success btn-sm">Checkout</button>
                                    </form>
                                }
                                @if (role == "ITAdmin")
                                {
                                    <a asp-action="Edit" asp-route-id="@item.EquipmentId"
                                       class="btn btn-outline-primary btn-sm ms-1">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.EquipmentId"
                                       class="btn btn-outline-danger btn-sm ms-1">Delete</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
