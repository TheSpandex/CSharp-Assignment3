@model _991733370_ASSET_CLIENT.Models.UpdateUserViewModel
@{
    ViewData["Title"] = "My Profile";
    var user = ViewBag.User as _991733370_ASSET_CLIENT.Models.UserDto;
}

<div class="row g-4 mt-1">
    <!-- Current Info -->
    <div class="col-md-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">Current Profile</h5>
            </div>
            <div class="card-body">
                @if (user is not null)
                {
                    <table class="table table-borderless mb-0">
                        <tr><th>Email</th><td>@user.Email</td></tr>
                        <tr><th>Employee ID</th><td>@user.EmployeeId</td></tr>
                        <tr><th>Department</th><td>@user.Department</td></tr>
                        <tr><th>Phone</th><td>@(user.PhoneNumber ?? "—")</td></tr>
                        <tr>
                            <th>Role(s)</th>
                            <td>
                                @foreach (var r in user.Roles)
                                {
                                    <span class="badge @(r == "ITAdmin" ? "bg-warning text-dark" : "bg-success") me-1">@r</span>
                                }
                            </td>
                        </tr>
                    </table>
                }
                else
                {
                    <p class="text-muted">Could not load profile data.</p>
                }
            </div>
        </div>
    </div>

    <!-- Update Form -->
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Update Profile</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.Error is string err)
                {
                    <div class="alert alert-danger">@err</div>
                }

                <form asp-action="Index" method="post">
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label">New Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Leave blank to keep current" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                    <hr />
                    <p class="text-muted small">To change your password, fill in both fields below.</p>
                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                        <input asp-for="CurrentPassword" type="password" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">New Password</label>
                        <input asp-for="NewPassword" type="password" class="form-control"
                               placeholder="Min 6 characters" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
